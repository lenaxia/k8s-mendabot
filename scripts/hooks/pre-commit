#!/usr/bin/env bash
# pre-commit — runs on every `git commit`
# Checks: (1) no secrets
# Install via: make install-hooks

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

pass() { printf "${GREEN}[OK]${NC}  %s\n" "$1"; }
fail() { printf "${RED}[FAIL]${NC} %s\n" "$1"; }
warn() { printf "${YELLOW}[WARN]${NC} %s\n" "$1"; }
info() { printf "      %s\n" "$1"; }

ERRORS=0

# ─── 1. Secrets scan ──────────────────────────────────────────────────────────
printf "\n==> Checking for secrets (gitleaks)...\n"
if ! command -v gitleaks &>/dev/null; then
  warn "gitleaks not found — skipping secrets scan."
  warn "Install with: go install github.com/zricethezav/gitleaks/v8@latest"
else
  # Scan only staged files so the check is fast and targeted
  if gitleaks protect --staged --config .gitleaks.toml --redact --no-banner 2>&1; then
    pass "No secrets detected"
  else
    fail "Secrets detected in staged files — commit blocked."
    info "Run 'gitleaks protect --staged --config .gitleaks.toml' for details."
    info "If this is a false positive, add an allowlist entry to .gitleaks.toml."
    ERRORS=$((ERRORS + 1))
  fi
fi

# ─── Result ───────────────────────────────────────────────────────────────────
printf "\n"
if [ "$ERRORS" -gt 0 ]; then
  fail "Pre-commit checks failed ($ERRORS error(s)). Commit aborted."
  exit 1
else
  pass "All pre-commit checks passed."
fi
