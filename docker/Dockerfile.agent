# ── age build stage — compiles age/age-keygen with Go 1.25.7 to eliminate stdlib CVEs ──
# Use go build -o to an explicit /out dir so the binary lands in a fixed path
# regardless of cross-compilation (go install puts cross-compiled binaries in
# $GOPATH/bin/${GOOS}_${GOARCH}/ which breaks COPY --from on multi-arch builds).
FROM golang:1.25.7-bookworm@sha256:0b5f101af6e4f905da4e1c5885a76b1e7a9fbc97b1a41d971dbcab7be16e70a1 AS age-builder
ARG AGE_VERSION=1.3.1
ARG TARGETARCH=amd64
RUN mkdir -p /out /build \
    && cd /build \
    && go mod init age-build \
    && go get filippo.io/age/cmd/age@v${AGE_VERSION} \
    && go get filippo.io/age/cmd/age-keygen@v${AGE_VERSION} \
    && CGO_ENABLED=0 GOOS=linux GOARCH=${TARGETARCH} \
       go build -trimpath -o /out/age filippo.io/age/cmd/age \
    && CGO_ENABLED=0 GOOS=linux GOARCH=${TARGETARCH} \
       go build -trimpath -o /out/age-keygen filippo.io/age/cmd/age-keygen

# ── Runtime image ─────────────────────────────────────────────────────────────
FROM debian:bookworm-slim@sha256:6458e6ce2b6448e31bfdced4be7d8aa88d389e6694ab09f5a718a694abe147f4

# Tool versions — bump these to upgrade
ARG KUBECTL_VERSION=1.35.1
ARG HELM_VERSION=3.20.0
ARG FLUX_VERSION=2.8.0
ARG TALOSCTL_VERSION=1.12.4
ARG KUSTOMIZE_VERSION=5.8.1
ARG YQ_VERSION=4.52.4
ARG KUBECONFORM_VERSION=0.7.0
ARG STERN_VERSION=1.33.1
ARG SOPS_VERSION=3.12.1
ARG OPENCODE_VERSION=1.2.10
ARG YQ_SHA256_AMD64=0c4d965ea944b64b8fddaf7f27779ee3034e5693263786506ccd1c120f184e8c
ARG YQ_SHA256_ARM64=4c2cc022a129be5cc1187959bb4b09bebc7fb543c5837b93001c68f97ce39a5d
ARG OPENCODE_SHA256_AMD64=ebcc24012e8f067b10d7416430c88e9c429115ecfbccf8da9eb59db3b629a358
ARG OPENCODE_SHA256_ARM64=d9a9d4f0bc1ed246258c0e8846e80593755a72bf4afd3940c4071d6f0b7b7775
ARG TARGETARCH=amd64

ENV DEBIAN_FRONTEND=noninteractive

# Base system packages (includes gettext-base for envsubst)
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    gettext-base \
    git \
    gnupg \
    jq \
    openssl \
    unzip \
    && rm -rf /var/lib/apt/lists/*

# gh CLI (GitHub's official apt repo — GPG-signed, no manual checksum needed)
# Note: use `install -m 0644 /dev/stdin` instead of `dd` for portability
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      | install -m 0644 /dev/stdin /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends gh \
    && rm -rf /var/lib/apt/lists/*

# kubectl — with SHA256 verification
RUN curl -fsSL "https://dl.k8s.io/release/v${KUBECTL_VERSION}/bin/linux/${TARGETARCH}/kubectl" \
      -o /usr/local/bin/kubectl \
    && curl -fsSL "https://dl.k8s.io/release/v${KUBECTL_VERSION}/bin/linux/${TARGETARCH}/kubectl.sha256" \
      -o /tmp/kubectl.sha256 \
    && echo "$(cat /tmp/kubectl.sha256)  /usr/local/bin/kubectl" | sha256sum --check \
    && rm /tmp/kubectl.sha256 \
    && chmod +x /usr/local/bin/kubectl

# helm — tarball; verify checksum from get.helm.sh
RUN curl -fsSL "https://get.helm.sh/helm-v${HELM_VERSION}-linux-${TARGETARCH}.tar.gz" \
      -o /tmp/helm.tar.gz \
    && curl -fsSL "https://get.helm.sh/helm-v${HELM_VERSION}-linux-${TARGETARCH}.tar.gz.sha256sum" \
      | awk '{print $1 "  /tmp/helm.tar.gz"}' | sha256sum --check \
    && tar -xz -C /usr/local/bin --strip-components=1 -f /tmp/helm.tar.gz "linux-${TARGETARCH}/helm" \
    && rm /tmp/helm.tar.gz

# flux — with CHECKSUMS (add retries)
RUN curl -fsSL --retry 3 --retry-delay 5 "https://github.com/fluxcd/flux2/releases/download/v${FLUX_VERSION}/flux_${FLUX_VERSION}_linux_${TARGETARCH}.tar.gz" \
      -o /tmp/flux.tar.gz \
    && curl -fsSL --retry 3 --retry-delay 5 "https://github.com/fluxcd/flux2/releases/download/v${FLUX_VERSION}/flux_${FLUX_VERSION}_checksums.txt" \
      | grep "flux_${FLUX_VERSION}_linux_${TARGETARCH}.tar.gz$" \
      | awk '{print $1 "  /tmp/flux.tar.gz"}' | sha256sum --check \
    && tar -xz -C /usr/local/bin -f /tmp/flux.tar.gz flux \
    && rm /tmp/flux.tar.gz

# talosctl — with SHA256 sidecar file (add retries)
RUN curl -fsSL --retry 3 --retry-delay 5 "https://github.com/siderolabs/talos/releases/download/v${TALOSCTL_VERSION}/talosctl-linux-${TARGETARCH}" \
      -o /tmp/talosctl \
    && curl -fsSL --retry 3 --retry-delay 5 "https://github.com/siderolabs/talos/releases/download/v${TALOSCTL_VERSION}/sha256sum.txt" \
      | grep "talosctl-linux-${TARGETARCH}$" \
      | awk '{print $1 "  /tmp/talosctl"}' | sha256sum --check \
    && mv /tmp/talosctl /usr/local/bin/talosctl \
    && chmod +x /usr/local/bin/talosctl

# kustomize — with checksums from GitHub releases (add retries for transient GitHub errors)
RUN curl -fsSL --retry 3 --retry-delay 5 "https://github.com/kubernetes-sigs/kustomize/releases/download/kustomize/v${KUSTOMIZE_VERSION}/kustomize_v${KUSTOMIZE_VERSION}_linux_${TARGETARCH}.tar.gz" \
      -o /tmp/kustomize.tar.gz \
    && curl -fsSL --retry 3 --retry-delay 5 "https://github.com/kubernetes-sigs/kustomize/releases/download/kustomize/v${KUSTOMIZE_VERSION}/checksums.txt" \
      | grep "kustomize_v${KUSTOMIZE_VERSION}_linux_${TARGETARCH}.tar.gz$" \
      | awk '{print $1 "  /tmp/kustomize.tar.gz"}' | sha256sum --check \
    && tar -xz -C /usr/local/bin -f /tmp/kustomize.tar.gz kustomize \
    && rm /tmp/kustomize.tar.gz

# yq — embed SHA256 per arch; checksums file format is non-standard so we pin values directly
RUN EXPECTED=$([ "$TARGETARCH" = "amd64" ] && echo "${YQ_SHA256_AMD64}" || echo "${YQ_SHA256_ARM64}") \
    && curl -fsSL --retry 3 --retry-delay 5 "https://github.com/mikefarah/yq/releases/download/v${YQ_VERSION}/yq_linux_${TARGETARCH}" \
      -o /usr/local/bin/yq \
    && echo "${EXPECTED}  /usr/local/bin/yq" | sha256sum --check \
    && chmod +x /usr/local/bin/yq

# kubeconform — with checksums (add retries)
RUN curl -fsSL --retry 3 --retry-delay 5 "https://github.com/yannh/kubeconform/releases/download/v${KUBECONFORM_VERSION}/kubeconform-linux-${TARGETARCH}.tar.gz" \
      -o /tmp/kubeconform.tar.gz \
    && curl -fsSL --retry 3 --retry-delay 5 "https://github.com/yannh/kubeconform/releases/download/v${KUBECONFORM_VERSION}/CHECKSUMS" \
      | grep "kubeconform-linux-${TARGETARCH}.tar.gz$" \
      | awk '{print $1 "  /tmp/kubeconform.tar.gz"}' | sha256sum --check \
    && tar -xz -C /usr/local/bin -f /tmp/kubeconform.tar.gz kubeconform \
    && rm /tmp/kubeconform.tar.gz

# stern — with checksums (add retries)
RUN curl -fsSL --retry 3 --retry-delay 5 "https://github.com/stern/stern/releases/download/v${STERN_VERSION}/stern_${STERN_VERSION}_linux_${TARGETARCH}.tar.gz" \
      -o /tmp/stern.tar.gz \
    && curl -fsSL --retry 3 --retry-delay 5 "https://github.com/stern/stern/releases/download/v${STERN_VERSION}/checksums.txt" \
      | grep "stern_${STERN_VERSION}_linux_${TARGETARCH}.tar.gz$" \
      | awk '{print $1 "  /tmp/stern.tar.gz"}' | sha256sum --check \
    && tar -xz -C /usr/local/bin -f /tmp/stern.tar.gz stern \
    && rm /tmp/stern.tar.gz

# age — compiled from source with Go 1.25.7 to eliminate stdlib CVEs in upstream pre-built binaries
COPY --from=age-builder /out/age /usr/local/bin/age
COPY --from=age-builder /out/age-keygen /usr/local/bin/age-keygen

# sops — sops releases use .checksums.txt (lowercase, with dot) (add retries)
RUN curl -fsSL --retry 3 --retry-delay 5 "https://github.com/getsops/sops/releases/download/v${SOPS_VERSION}/sops-v${SOPS_VERSION}.linux.${TARGETARCH}" \
      -o /usr/local/bin/sops \
    && curl -fsSL --retry 3 --retry-delay 5 "https://github.com/getsops/sops/releases/download/v${SOPS_VERSION}/sops-v${SOPS_VERSION}.checksums.txt" \
      | grep "sops-v${SOPS_VERSION}.linux.${TARGETARCH}$" \
      | awk '{print $1 "  /usr/local/bin/sops"}' | sha256sum --check \
    && chmod +x /usr/local/bin/sops

# opencode — pinned release binary; use glibc builds to match debian:bookworm-slim base image
RUN ARCH=$([ "$TARGETARCH" = "amd64" ] && echo "x64" || echo "arm64") \
    && EXPECTED=$([ "$TARGETARCH" = "amd64" ] && echo "${OPENCODE_SHA256_AMD64}" || echo "${OPENCODE_SHA256_ARM64}") \
    && curl -fsSL --retry 3 --retry-delay 5 "https://github.com/sst/opencode/releases/download/v${OPENCODE_VERSION}/opencode-linux-${ARCH}.tar.gz" \
      -o /tmp/opencode.tar.gz \
    && echo "${EXPECTED}  /tmp/opencode.tar.gz" | sha256sum --check \
    && tar -xz -C /usr/local/bin -f /tmp/opencode.tar.gz opencode \
    && rm /tmp/opencode.tar.gz

# Non-root user
RUN useradd -u 1000 -m -s /bin/bash agent

# Git identity for commits made by the agent
# Use a GitHub noreply address format: <app-id>+<slug>@users.noreply.github.com
ENV GIT_AUTHOR_NAME="mendabot-agent"
ENV GIT_AUTHOR_EMAIL="mendabot-agent@users.noreply.github.com"
ENV GIT_COMMITTER_NAME="mendabot-agent"
ENV GIT_COMMITTER_EMAIL="mendabot-agent@users.noreply.github.com"

# GitHub App token helper (writes token to stdout)
COPY docker/scripts/get-github-app-token.sh /usr/local/bin/get-github-app-token.sh
RUN chmod +x /usr/local/bin/get-github-app-token.sh

# Agent entrypoints: dispatcher + shared common setup + per-agent-runner scripts
COPY docker/scripts/agent-entrypoint.sh /usr/local/bin/agent-entrypoint.sh
COPY docker/scripts/entrypoint-common.sh /usr/local/bin/entrypoint-common.sh
COPY docker/scripts/entrypoint-opencode.sh /usr/local/bin/entrypoint-opencode.sh
COPY docker/scripts/entrypoint-claude.sh /usr/local/bin/entrypoint-claude.sh
RUN chmod +x /usr/local/bin/agent-entrypoint.sh \
             /usr/local/bin/entrypoint-common.sh \
             /usr/local/bin/entrypoint-opencode.sh \
             /usr/local/bin/entrypoint-claude.sh

# Smoke test: verifies all expected binaries are present and executable
COPY docker/scripts/smoke-test.sh /usr/local/bin/smoke-test.sh
RUN chmod +x /usr/local/bin/smoke-test.sh

USER agent
WORKDIR /workspace

ENTRYPOINT ["/usr/local/bin/agent-entrypoint.sh"]
