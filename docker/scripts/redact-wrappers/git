#!/usr/bin/env bash
# git wrapper — blocks write subcommands when DRY_RUN=true.
# Pass-through for all read-only operations; does not redact stdout.
# Does NOT use set -e: the real binary may exit non-zero legitimately.
#
# git is installed by apt to /usr/bin/git; renamed to /usr/bin/git.real by
# Dockerfile.agent. This wrapper is installed at /usr/local/bin/git which
# takes precedence in PATH.

# Dry-run enforcement — three independent layers, defense-in-depth.
# Any single layer returning "true" is sufficient to enforce dry-run mode.
#
#   Layer 1 — /mechanic-cfg/dry-run sentinel file (chmod 444, read-only volume mount).
#              Written by the dry-run-gate init container; cannot be removed or
#              modified by any child process inside the agent container.
#
#   Layer 2 — /proc/1/environ (PID-1 / container entrypoint environment).
#              Immutable from inside the container; unaffected by child unset.
#
#   Layer 3 — Current shell $DRY_RUN env var.
#              Last-resort fallback. Can be bypassed by "unset DRY_RUN" but
#              layers 1 and 2 cover that attack.
_dry_run="false"

# Layer 1: sentinel file (tamper-proof read-only mount)
if [ -f /mechanic-cfg/dry-run ] && [ "$(cat /mechanic-cfg/dry-run 2>/dev/null)" = "true" ]; then
    _dry_run="true"
fi

# Layer 2: /proc/1/environ (immutable container-init env)
if [ "$_dry_run" = "false" ] && [ -r /proc/1/environ ]; then
    if tr '\0' '\n' < /proc/1/environ 2>/dev/null | grep -q '^DRY_RUN=true$'; then
        _dry_run="true"
    fi
fi

# Layer 3: current shell env var (fallback / local testing)
if [ "$_dry_run" = "false" ] && [ "${DRY_RUN:-false}" = "true" ]; then
    _dry_run="true"
fi

if [ "$_dry_run" = "true" ]; then
    case "${1:-}" in
        push|commit)
            echo "[DRY_RUN] git $* blocked — write operations are disabled in dry-run mode" >&2
            exit 0
            ;;
        reset|rm|clean|rebase)
            echo "[DRY_RUN] git $* blocked — write operations are disabled in dry-run mode" >&2
            exit 0
            ;;
        config)
            # Block mutations to the global or system config; allow local config
            # reads (--get, --list without --global/--system) which are read-only.
            for _arg in "$@"; do
                case "$_arg" in
                    --global|--system)
                        echo "[DRY_RUN] git $* blocked — write operations are disabled in dry-run mode" >&2
                        exit 0
                        ;;
                esac
            done
            ;;
        remote)
            # Block set-url which can redirect pushes to an attacker-controlled repo.
            if [ "${2:-}" = "set-url" ]; then
                echo "[DRY_RUN] git $* blocked — write operations are disabled in dry-run mode" >&2
                exit 0
            fi
            ;;
        tag)
            # Block annotated (-a) and signed (-s) tags; allow lightweight tags
            # (used internally by some tools for version queries).
            for _arg in "$@"; do
                case "$_arg" in
                    -a|-s|--annotate|--sign)
                        echo "[DRY_RUN] git $* blocked — write operations are disabled in dry-run mode" >&2
                        exit 0
                        ;;
                esac
            done
            ;;
    esac
fi

exec /usr/bin/git.real "$@"
