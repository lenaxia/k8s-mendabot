#!/usr/bin/env bash
# gh wrapper — allowlist approach for dry-run mode.
# In dry-run mode only read-only operations are permitted.
# Write operations are blocked fail-closed: anything not explicitly allowed is denied.
# Outside dry-run mode, all commands pass through (stdout/stderr piped through redact).
# Does NOT use set -e: the real binary may exit non-zero legitimately.

if ! command -v redact > /dev/null 2>&1; then
    echo "[ERROR] redact binary not found in PATH — aborting to prevent unredacted output" >&2
    exit 1
fi

# Dry-run enforcement — three independent layers, defense-in-depth.
# Any single layer returning "true" is sufficient to enforce dry-run mode.
#
#   Layer 1 — /mechanic-cfg/dry-run sentinel file (chmod 444, read-only volume mount).
#              Written by the dry-run-gate init container before this container
#              starts. The main container mounts the emptyDir read-only, so no
#              child process can delete or modify the file — including via
#              "unset DRY_RUN" or any other shell manipulation.
#
#   Layer 2 — /proc/1/environ (PID-1 / container entrypoint environment).
#              Set by the Kubernetes Job spec at container creation time.
#              Immutable from inside the container; unaffected by child unset.
#
#   Layer 3 — Current shell $DRY_RUN env var.
#              Last-resort fallback for local testing / environments where
#              /proc is unavailable. Can be bypassed by "unset DRY_RUN" but
#              layers 1 and 2 cover that attack.
_dry_run="false"

# Layer 1: sentinel file (tamper-proof read-only mount)
if [ -f /mechanic-cfg/dry-run ] && [ "$(cat /mechanic-cfg/dry-run 2>/dev/null)" = "true" ]; then
    _dry_run="true"
fi

# Layer 2: /proc/1/environ (immutable container-init env)
if [ "$_dry_run" = "false" ] && [ -r /proc/1/environ ]; then
    if tr '\0' '\n' < /proc/1/environ 2>/dev/null | grep -q '^DRY_RUN=true$'; then
        _dry_run="true"
    fi
fi

# Layer 3: current shell env var (fallback / local testing)
if [ "$_dry_run" = "false" ] && [ "${DRY_RUN:-false}" = "true" ]; then
    _dry_run="true"
fi

if [ "$_dry_run" = "true" ]; then
    # ---------------------------------------------------------------------------
    # Allowlist enforcement (fail-closed).
    # Only explicitly approved read-only operations are permitted.
    # Everything else is blocked.
    # ---------------------------------------------------------------------------

    _cmd="${1:-}"
    _sub="${2:-}"
    _allowed="false"

    # Check for write HTTP method in gh api calls.
    # Scan all arguments for -X/--method followed by a write method.
    _write_method="false"
    _prev=""
    for _arg in "$@"; do
        case "$_prev" in
            -X|--method)
                case "$_arg" in
                    POST|PUT|PATCH|DELETE|post|put|patch|delete)
                        _write_method="true"
                        ;;
                esac
                ;;
        esac
        # Also handle --method=VALUE form
        case "$_arg" in
            --method=POST|--method=PUT|--method=PATCH|--method=DELETE|\
            --method=post|--method=put|--method=patch|--method=delete)
                _write_method="true"
                ;;
        esac
        _prev="$_arg"
    done

    case "$_cmd" in
        # gh api: allow GET (explicit or implicit default); block everything with
        # a write HTTP method.
        api)
            if [ "$_write_method" = "false" ]; then
                _allowed="true"
            fi
            ;;

        # auth: allow status and token queries (read-only credential inspection).
        auth)
            case "$_sub" in
                status|token) _allowed="true" ;;
            esac
            ;;

        # repo: allow view, list, clone only.
        repo)
            case "$_sub" in
                view|list|clone) _allowed="true" ;;
            esac
            ;;

        # pr: allow view, list, checks, diff, review (read-only inspect operations).
        pr)
            case "$_sub" in
                view|list|checks|diff|review) _allowed="true" ;;
            esac
            ;;

        # issue: allow view, list (read-only inspect operations).
        issue)
            case "$_sub" in
                view|list) _allowed="true" ;;
            esac
            ;;

        # run: allow view, list, watch (read-only CI inspection).
        run)
            case "$_sub" in
                view|list|watch) _allowed="true" ;;
            esac
            ;;

        # release: allow view, list, download (read-only artifact inspection).
        release)
            case "$_sub" in
                view|list|download) _allowed="true" ;;
            esac
            ;;

        # workflow: allow view, list (read-only workflow inspection).
        workflow)
            case "$_sub" in
                view|list) _allowed="true" ;;
            esac
            ;;
    esac

    if [ "$_allowed" = "false" ]; then
        echo "[DRY_RUN] gh $* blocked — write operations are disabled in dry-run mode" >&2
        exit 0
    fi
fi

_tmpfile=$(mktemp) || { echo "[ERROR] mktemp failed — aborting" >&2; exit 1; }
trap 'rm -f "$_tmpfile"' EXIT

/usr/bin/gh "$@" > "$_tmpfile" 2>&1
_rc=$?

redact < "$_tmpfile"
_rr=$?
[ "$_rr" -ne 0 ] && exit "$_rr"
exit "$_rc"
