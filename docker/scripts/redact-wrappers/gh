#!/usr/bin/env bash
# gh wrapper — gh is installed by apt to /usr/bin/gh; call it by absolute path.
# Does NOT use set -e: the real binary may exit non-zero legitimately.

if ! command -v redact > /dev/null 2>&1; then
    echo "[ERROR] redact binary not found in PATH — aborting to prevent unredacted output" >&2
    exit 1
fi

# Dry-run enforcement: block write subcommands that create, modify, or comment on
# GitHub resources. This is a deterministic control — the LLM cannot bypass it by
# rephrasing a prompt instruction or unsetting DRY_RUN in a child shell.
#
# We read DRY_RUN from /proc/1/environ (the PID-1 / container entrypoint
# environment) rather than the current shell environment. This makes the check
# tamper-proof: a child process cannot unset or override the value that was
# injected by the Kubernetes Job spec.
_dry_run_val="false"
if [ -r /proc/1/environ ]; then
    # /proc/1/environ is NUL-delimited; grep for the exact variable.
    if tr '\0' '\n' < /proc/1/environ 2>/dev/null | grep -q '^DRY_RUN=true$'; then
        _dry_run_val="true"
    fi
else
    # Fallback for environments where /proc/1/environ is not readable.
    _dry_run_val="${DRY_RUN:-false}"
fi

if [ "$_dry_run_val" = "true" ]; then
    case "${1:-}" in
        pr|issue|release|gist|workflow)
            case "${2:-}" in
                create|edit|close|merge|delete|comment|reopen|label|lock|unlock|transfer|run|dispatch|enable|disable)
                    echo "[DRY_RUN] gh $* blocked — write operations are disabled in dry-run mode" >&2
                    exit 0
                    ;;
            esac
            ;;
    esac
fi

_tmpfile=$(mktemp) || { echo "[ERROR] mktemp failed — aborting" >&2; exit 1; }
trap 'rm -f "$_tmpfile"' EXIT

/usr/bin/gh "$@" > "$_tmpfile" 2>&1
_rc=$?

redact < "$_tmpfile"
_rr=$?
[ "$_rr" -ne 0 ] && exit "$_rr"
exit "$_rc"
