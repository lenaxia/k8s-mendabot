{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "agentType": {
      "type": "string",
      "enum": ["opencode", "claude"],
      "description": "Agent runner type. Controls which AI agent binary runs inside the Job."
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "image": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" }
          }
        }
      }
    },
    "gitops": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repo": { "type": "string" },
        "manifestRoot": { "type": "string" }
      }
    },
    "watcher": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stabilisationWindowSeconds": { "type": "integer", "minimum": 0 },
        "maxConcurrentJobs": { "type": "integer", "minimum": 1 },
        "remediationJobTTLSeconds": { "type": "integer", "minimum": 1 },
        "sinkType": { "type": "string" },
        "logLevel": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"]
        },
        "llmProvider": {
          "type": "string",
          "enum": ["", "openai"],
          "description": "LLM readiness gate. 'openai' enables it; empty disables."
        },
        "injectionDetectionAction": {
          "type": "string",
          "enum": ["log", "suppress"]
        },
        "agentRBACScope": {
          "type": "string",
          "enum": ["cluster", "namespace"]
        },
        "agentWatchNamespaces": {
          "type": "string",
          "description": "Comma-separated namespaces. Required when agentRBACScope=namespace."
        },
        "watchNamespaces": {
          "type": "string",
          "description": "Comma-separated namespaces the watcher monitors. Empty = all namespaces."
        },
        "excludeNamespaces": {
          "type": "string",
          "description": "Comma-separated namespaces the watcher ignores. Empty = no exclusions."
        },
        "maxInvestigationRetries": {
          "type": "string",
          "description": "Maximum investigation retries per RemediationJob before permanently failing."
        },
        "dryRun": {
          "type": "boolean",
          "description": "Enable dry-run shadow mode. Blocks write operations; stores investigation reports in RemediationJob.status.message."
        },
        "correlationWindowSeconds": {
          "type": "integer",
          "minimum": 0,
          "description": "Seconds to hold Pending jobs before the correlator fires. Defaults to stabilisationWindowSeconds when unset. Set to 0 to skip the hold but still run the correlator."
        },
        "disableCorrelation": {
          "type": "boolean",
          "description": "Disable all correlation logic and dispatch immediately. Default is false."
        },
        "multiPodThreshold": {
          "type": "integer",
          "minimum": 1,
          "description": "Minimum number of pods failing on the same node to trigger MultiPodSameNodeRule. Default is 3."
        }
      }
    },
    "prompt": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "coreOverride": { "type": "string" },
        "agentOverride": { "type": "string" }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "apiServerPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "additionalEgressRules": { "type": "array" }
      }
    },
    "rbac": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": { "type": "boolean" }
      }
    },
    "secrets": {
      "type": "object",
      "description": "Placeholder — no configurable fields; secret names are derived from agentType in job.go"
    },
    "selfRemediation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxDepth": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum self-remediation chain depth. 0 disables self-remediation entirely. Default is 2."
        },
        "cooldownSeconds": {
          "type": "integer",
          "minimum": 0,
          "description": "Minimum seconds between successive self-remediation attempts. 0 disables the circuit breaker. Default is 300."
        }
      }
    },
    "createNamespace": { "type": "boolean" },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "serviceMonitor": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "interval": { "type": "string" },
            "scrapeTimeout": { "type": "string" },
            "labels": { "type": "object" }
          }
        }
      }
    }
  }
}
